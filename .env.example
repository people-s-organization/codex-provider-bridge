# Optional: if you already have a valid ChatGPT Web access token, put it here.
CHATGPT_ACCESS_TOKEN=

# Optional: required for /v1/audio/speech and as an image fallback.
# /v1/images/generations prefers the ChatGPT/Codex image_generation tool when
# CHATGPT_ACCESS_TOKEN is available.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
CHATGPT_ACCOUNT_ID=

# Auth preference:
# - auto: if token sources 1/2 are missing and the terminal is interactive,
#         ask you to choose browser login or device-code at startup
# - browser: always try browser login first
# - device: always use device-code
# - prompt: always ask which login flow to use
# Note: CLI --auth takes precedence over this env var.
CHATGPT_AUTH_METHOD=prompt

# Server bind configuration
HOST=0.0.0.0
PORT=8000

# Optional upstream override
CHATGPT_BASE_URL=https://chatgpt.com

# Optional model registry override.
# If CHATGPT_MODELS is empty, the bridge reads ~/.codex/models_cache.json first,
# then falls back to a conservative built-in list.
# Examples:
# CHATGPT_MODELS=gpt-5.5,gpt-image-2,gpt-4o-mini-tts
# CHATGPT_EXTRA_MODELS=gpt-custom
# CHATGPT_DEFAULT_MODEL=gpt-5.5
# CHATGPT_MEDIA_MODEL=gpt-5.5
# CHATGPT_REALTIME_MODEL=gpt-realtime-1.5
CHATGPT_MODELS=
CHATGPT_EXTRA_MODELS=
CHATGPT_DEFAULT_MODEL=
CHATGPT_MEDIA_MODEL=
CHATGPT_REALTIME_MODEL=
CHATGPT_MODELS_FILE=~/.codex/models_cache.json
CHATGPT_CODEX_CONFIG_FILE=~/.codex/config.toml

# Optional aliases for client compatibility.
# JSON object or comma-separated pairs are supported.
# Examples:
# CHATGPT_MODEL_ALIASES={"gpt-4.1":"gpt-5.5","gpt-4.1-mini":"gpt-5.4-mini"}
# CHATGPT_EXTRA_MODEL_ALIASES=gpt-old=gpt-5.5
CHATGPT_MODEL_ALIASES=
CHATGPT_EXTRA_MODEL_ALIASES=
